{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/webhooks/kommo",
      "dest": "/api/webhooks/kommo/index.ts"
    },
    {
      "src": "/api/webhooks/stripe",
      "dest": "/api/webhooks/stripe/index.ts"
    },
    {
      "src": "/api/health",
      "dest": "/api/health/index.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ],
  "env": {
    "KOMMO_BASE_URL": "https://alexgrundy.kommo.com"
  }
}
